# Korapay Payment Gateway Configuration
# Get these credentials from https://dashboard.korapay.com
KORAPAY_SECRET_KEY=
KORAPAY_PUBLIC_KEY=
KORAPAY_WEBHOOK_SECRET=

# API Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session Configuration (optional, defaults provided)
SESSION_SECRET=

# Email Configuration (optional, for notifications)
SMTP_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
