# Database Configuration (Neon PostgreSQL)
DATABASE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
